{
    "compilerOptions": {
      "target": "es2022",
      "module": "esnext",
      "moduleResolution": "bundler",
      "esModuleInterop": true,
      "allowSyntheticDefaultImports": true,
      "skipLibCheck": true,
      "noEmit": true,
      "noEmitOnError": false,
      "strict": false,
      "types": ["node"]
    },
    "include": ["./*.ts"]
  }
  