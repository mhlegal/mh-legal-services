{
  "version": 2,
  "buildCommand": "pnpm --filter @workspace/api-server run build && pnpm --filter @workspace/mh-legal run build",
  "outputDirectory": "artifacts/mh-legal/dist/public",
  "installCommand": "pnpm install",
  "functions": {
    "api/[...path].ts": {
      "maxDuration": 10
    }
  },
  "rewrites": [
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ]
}
