{
    "$schema": "https://openapi.vercel.sh/vercel.json",
    "buildCommand": "pnpm run typecheck:libs && pnpm --filter @workspace/mh-legal run build",
    "outputDirectory": "artifacts/mh-legal/dist/public",
    "installCommand": "pnpm install --no-frozen-lockfile",
    "framework": null,
    "nodeVersion": "22.x",
    "functions": {
      "api/[...path].ts": {
        "maxDuration": 60
      }
    },
    "rewrites": [
      { "source": "/(.*)", "destination": "/index.html" }
    ],
    "headers": [
      {
        "source": "/assets/(.*)",
        "headers": [
          { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
        ]
      }
    ]
  }
  