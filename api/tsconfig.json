{
    "compilerOptions": {
      "target": "es2022",
      "module": "esnext",
      "moduleResolution": "bundler",
      "esModuleInterop": true,
      "allowSyntheticDefaultImports": true,
      "skipLibCheck": true,
      "noEmit": true,
      "noEmitOnError": false,
      "strict": false,
      "types": ["node"],
      "typeRoots": [
        "../artifacts/api-server/node_modules/@types",
        "../node_modules/@types"
      ]
    },
    "include": [
      "./*.ts",
      "../artifacts/api-server/src/types/*.d.ts"
    ]
  }
  